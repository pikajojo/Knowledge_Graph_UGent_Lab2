@prefix vocab:  <https://pikajojo.github.io/Knowledge_Graph_UGent_Lab2/vocab.ttl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Classes
#################################################################

vocab:Person
  a rdfs:Class ;
  rdfs:label "Person"@en ;
  rdfs:comment "A human person described in this dataset."@en .


vocab:Course 
  a rdfs:Class ;
    rdfs:label "Course"@en ;
    rdfs:comment "A course offered at an educational institution." .

vocab:City 
  a rdfs:Class ;
    rdfs:label "City"@en ;
    rdfs:comment "A place in this world with many people living in." .

#################################################################
# Datatype Properties (literal values)
#################################################################

vocab:name
  a rdf:Property ;
  rdfs:label "name"@en ;
  rdfs:comment "The full name of a person."@en ;
  rdfs:domain vocab:Person ;
  rdfs:range xsd:string .

vocab:hasHometown
  a rdf:Property ;
  rdfs:label "hometown"@en ;
  rdfs:comment "The hometown of a person (as a text literal)."@en ;
  rdfs:domain vocab:Person ;
  rdfs:range xsd:string .

vocab:hasJobTitle
  a rdf:Property ;
  rdfs:label "job title"@en ;
  rdfs:comment "The job title or role of a person."@en ;
  rdfs:domain vocab:Person ;
  rdfs:range xsd:string .

vocab:hasTelephone
  a rdf:Property ;
  rdfs:label "telephone"@en ;
  rdfs:comment "A telephone number of a person, stored as a string."@en ;
  rdfs:domain vocab:Person ;
  rdfs:range xsd:string .

vocab:hasHobby
  a rdf:Property ;
  rdfs:label "hobby"@en ;
  rdfs:comment "A hobby of a person."@en ;
  rdfs:domain vocab:Person ;
  rdfs:range xsd:string .





#################################################################
# Object Properties (IRI/resource values)
#################################################################

vocab:url
  a rdf:Property ;
  rdfs:label "url"@en ;
  rdfs:comment "A link (IRI) to a web resource related to the person (e.g., personal website)."@en ;
  rdfs:domain vocab:Person ;
  rdfs:range rdfs:Resource .

vocab:enrolledIn 
    a rdf:Property ;
    rdfs:label "enrolled in" ;
    rdfs:comment "Relates a person to a course they are enrolled in." ;
    rdfs:domain lab:Person ;
    rdfs:range lab:Course .

vocab:knows
  a rdf:Property ;
  rdfs:label "knows"@en ;
  rdfs:comment "Indicates that a person knows another person."@en ;
  rdfs:domain vocab:Person ;
  rdfs:range vocab:Person .

vocab:beFriendWith
  a rdf:Property ;
  rdfs:label "be friend with"@en ;
  rdfs:comment "Indicates that a person is friends with another person."@en ;
  rdfs:domain vocab:Person ;
  rdfs:range vocab:Person .